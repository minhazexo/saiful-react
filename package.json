{
  "name": "saiful-react",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n CLIENT,SERVER -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "build": "vite build",
    "build:gh": "cross-env VITE_BASE_PATH=/saiful-react/ VITE_ROUTER=hash VITE_DEMO_MODE=true vite build",
    "preview": "vite preview",
    "start": "cd server && npm start",
    "seed": "cd server && npm run seed",
    "migrate": "cd server && npm run migrate",
    "migrate:status": "cd server && npm run migrate:status",
    "migrate:undo": "cd server && npm run migrate:undo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:server": "cd server && npm test",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "lint": "eslint src e2e",
    "lint:fix": "eslint src e2e --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,html}\" \"e2e/**/*.{js,jsx}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,html}\" \"e2e/**/*.{js,jsx}\""
  },
  "dependencies": {
    "axios": "^1.17.0",
    "concurrently": "^9.1.0",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.17.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
