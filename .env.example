VITE_API_URL=http://localhost:5000/api

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=saiful_studios
DB_PORT=3306

# Server
PORT=5000
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Session cookie name (the auth cookie set on /api/auth/login)
# The cookie is httpOnly + sameSite=lax; secure flag is auto-set when NODE_ENV=production.
ADMIN_COOKIE_NAME=admin_token

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# Public site URL used for sitemap.xml and absolute links
PUBLIC_SITE_URL=http://localhost:5173

# Set DB_SYNC=true to let Sequelize auto-alter the schema on boot
# (useful in early development). In production, run migrations instead:
#   npm run migrate
DB_SYNC=false

# Seed admin (required for npm run seed)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Saiful Islam

# Optional: notification email for new contact submissions
NOTIFY_EMAIL=

# Optional: SMTP for outbound email (used by NOTIFY_EMAIL + contact auto-reply)
# Leave SMTP_HOST empty to disable email sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Saiful Studios <hello@saifulstudios.com>"
